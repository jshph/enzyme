{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/renderer/**/*"
, "src/main/utils"  ],
  "compilerOptions": {
    "composite": true,
    "types": ["electron-vite/node", "menubar"],
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/renderer/dashboard/*",
        "src/renderer/menubar/*"
      ]
    }
  }
}
