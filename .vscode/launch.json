{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Enzyme",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "${workspaceRoot}/node_modules/.bin/electron-vite",
      "runtimeArgs": ["--sourcemap"],
      "env": {
        "REMOTE_DEBUGGING_PORT": "9222"
      },
      "preLaunchTask": "Kill Electron Processes"
    },
    {
      "name": "Debug Renderer Process",
      "port": 9222,
      "request": "attach",
      "type": "chrome",
      "webRoot": "${workspaceFolder}/src/renderer",
      "timeout": 60000,
      "presentation": {
        "hidden": true
      }
    },
    {
      "name": "Debug Standalone Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceRoot}/../enzyme-standalone-server/node_modules/.bin/ts-node-dev",
      "runtimeArgs": ["--respawn", "--transpile-only"],
      "program": "${workspaceRoot}/../enzyme-standalone-server/src/digestServer.ts",
      "cwd": "${workspaceRoot}/../enzyme-standalone-server",
      "restart": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "sourceMaps": true
    },
    {
      "name": "Debug Jest Tests",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceRoot}/node_modules/.bin/jest",
      "args": ["--runInBand", "--config", "jest.config.ts"],
      "cwd": "${workspaceRoot}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Debug All",
      "configurations": ["Debug Enzyme", "Debug Renderer Process"],
      "presentation": {
        "order": 1
      }
    }
  ]
}